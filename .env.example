# === Database ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=travel_planner
DB_PASSWORD=changeme
DB_NAME=travel_planner

# === Redis (also used as task queue) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# === LLM (Multi-provider) ===
# Provider: "anthropic", "openai", or "openai_compatible"
LLM_PROVIDER=anthropic
# Generic API key (used by openai/openai_compatible, fallback for anthropic)
LLM_API_KEY=
# Base URL for OpenAI-compatible endpoints (e.g. OpenRouter, DeepSeek, Ollama)
LLM_BASE_URL=
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.3
# Anthropic-specific (backward compatible, falls back to LLM_API_KEY)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# === External APIs (optional, Phase 2) ===
AMAP_API_KEY=your_amap_key
WEATHER_API_KEY=your_weather_key

# === App ===
APP_NAME=travel-planner
APP_DEBUG=true
APP_LOG_LEVEL=INFO
